{
  "rules": [
    {
      "id": "expire-job-objects",
      "enabled": true,
      "conditions": {
        "prefix": "jobs/"
      },
      "deleteObjectsTransition": {
        "condition": {
          "type": "Age",
          "maxAge": 691200
        }
      }
    },
    {
      "id": "abort-incomplete-multipart-uploads",
      "enabled": true,
      "conditions": {},
      "abortMultipartUploadsTransition": {
        "condition": {
          "type": "Age",
          "maxAge": 604800
        }
      }
    }
  ]
}
