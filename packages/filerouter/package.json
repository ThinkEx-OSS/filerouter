{
  "name": "@file_router/sdk",
  "version": "0.3.0",
  "description": "Provider-neutral document parsing SDK.",
  "keywords": [
    "documents",
    "ocr",
    "parsing",
    "pdf",
    "typescript"
  ],
  "homepage": "https://filerouter.dev",
  "bugs": {
    "url": "https://github.com/ThinkEx-OSS/filerouter/issues"
  },
  "license": "MIT",
  "author": "ThinkEx Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThinkEx-OSS/filerouter.git",
    "directory": "packages/filerouter"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./inspect": {
      "types": "./dist/inspect.d.ts",
      "import": "./dist/inspect.js"
    },
    "./hosted": {
      "types": "./dist/hosted.d.ts",
      "import": "./dist/hosted.js",
      "default": "./dist/hosted.js"
    },
    "./llamaparse": {
      "types": "./dist/llamaparse.d.ts",
      "import": "./dist/llamaparse.js"
    },
    "./datalab": {
      "types": "./dist/datalab.d.ts",
      "import": "./dist/datalab.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.js"
    },
    "./mistral": {
      "types": "./dist/mistral.d.ts",
      "import": "./dist/mistral.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "file-type": "22.0.1"
  },
  "devDependencies": {
    "@llamaindex/llama-cloud": "^2.13.0",
    "@mistralai/mistralai": "^2.5.0",
    "@types/node": "^26",
    "tsup": "^8.5.1",
    "typescript": "^7",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@llamaindex/llama-cloud": "^2.13.0",
    "@mistralai/mistralai": "^2.5.0"
  },
  "peerDependenciesMeta": {
    "@llamaindex/llama-cloud": {
      "optional": true
    },
    "@mistralai/mistralai": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.14.0"
  }
}
